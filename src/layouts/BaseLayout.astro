---
import ExplorerSidebar from '../components/ExplorerSidebar.astro';

export interface Props {
  title: string;
  currentSlug?: string;
  headings?: { depth: number; slug: string; text: string }[];
  showToc?: boolean;
}

const { title, currentSlug = '', headings = [], showToc = false } = Astro.props;
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title} | Log</title>
    <meta name="description" content="Notes of research, experiments, and troubleshooting." />
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <div class="nav-brand">
          <a href="/">eesungkim</a>
        </div>
        <ul class="nav-menu">
          <li><a href="/">Home</a></li>
          <li><a href="/reviews/">Log</a></li>
          <li><a href="/search/">Search</a></li>
        </ul>
      </div>
    </header>

    <div class="page-wrapper">
      <aside class="sidebar">
        <ExplorerSidebar currentSlug={currentSlug} />
      </aside>

      <main class="site-main">
        <slot />
      </main>

      <aside class="toc-wrapper">
        {showToc && tocHeadings.length > 0 && (
          <div class="toc-panel">
            <p class="toc-label">On this page</p>
            <nav>
              <ul class="toc-list">
                {tocHeadings.map(h => (
                  <li class={`toc-item toc-h${h.depth}`}>
                    <a href={`#${h.slug}`}>{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        )}
      </aside>
    </div>

    <footer class="site-footer">
      <p>&copy; 2026 eesungkim.com</p>
    </footer>
  </body>
</html>
